:{$PORT:8080} {
    root * .
    encode gzip

    # Redirect non-canonical hostnames (Railway URL, www) to the canonical domain
    @non_canonical {
        not header Host linkwithmitch.com
        not header Host localhost
        not header Host ""
    }
    redir @non_canonical https://linkwithmitch.com{uri} permanent

    file_server

    # Try to serve the exact file, then try index.html in directory, then 404
    try_files {path} {path}/index.html /404.html

    # Handle errors
    handle_errors {
        @404 {
            expression {http.error.status_code} == 404
        }
        rewrite @404 /404.html
        file_server
    }
}
