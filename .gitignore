# Ignore system files
.DS_Store
Thumbs.db
desktop.ini

# Ignore temporary files
*.tmp
*.log
*~

# Ignore editor files
.vscode/
.idea/
*.swp
*.swo

# Ignore Node modules if added later
node_modules/

# Exclude .git folder from Cloudflare Workers asset uploads
.git/

# Wrangler auto-generated files
.wrangler/
wrangler.jsonc

# Keep these
!.gitignore

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
.env*
!.env.example
